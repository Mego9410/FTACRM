{
  "name": "ftacrm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:reset:local": "psql -h /var/run/postgresql -p 54322 -U postgres -c 'drop database if exists ftacrm' -c 'create database ftacrm' && npm run db:apply:local",
    "db:apply:local": "for f in supabase/migrations/*.sql; do psql -h /var/run/postgresql -p 54322 -U postgres -d ftacrm -v ON_ERROR_STOP=1 -f \"$f\" || exit 1; done && psql -h /var/run/postgresql -p 54322 -U postgres -d ftacrm -v ON_ERROR_STOP=1 -f supabase/seed.sql",
    "db:seed:demo:local": "psql -h /var/run/postgresql -p 54322 -U postgres -d ftacrm -v ON_ERROR_STOP=1 -f supabase/seed_demo.sql"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.25.0",
    "next": "^15.5.20",
    "nextjs-toploader": "^3.9.17",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^1.5.2",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "1.3.5",
    "eslint": "^9",
    "eslint-config-next": "^15.5.20",
    "tailwindcss": "^4.3.3",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
